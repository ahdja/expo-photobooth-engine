{
  "name": "@kotaksurat/expo-photobooth-engine",
  "version": "1.0.0",
  "description": "Photobooth engine for Expo React Native",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepare": "npm run build",
    "test": "vitest"
  },
  "keywords": [
    "expo",
    "react-native",
    "photobooth",
    "canvas",
    "image-processing"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@shopify/react-native-skia": ">= 1.2.0",
    "react": ">= 18.0.0",
    "react-native": ">= 0.72.0"
  },
  "devDependencies": {
    "@types/react-native": "^0.72.8",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}